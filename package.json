{
  "name": "mugi-claw",
  "version": "0.1.0",
  "description": "AI Assistant Slack App powered by Claude Code CLI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/bolt": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "nanoid": "^5.1.7",
    "node-cron": "^4.2.1",
    "node-screenshots": "^0.2.8",
    "pino": "^9.6.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
