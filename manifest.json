{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "mugi-claw",
    "description": "AIアシスタント犬むぎぼー。Claude Code CLIでタスクを実行するわん！",
    "background_color": "#F5A623",
    "long_description": "Slackに常駐するAIアシスタント「むぎぼー」です。@メンションでClaude Code CLIにタスクを委譲し、進捗をリアルタイムにスレッドに投稿します。Playwright + Chrome DevTools Protocolによるブラウザ操作で、Gmail検索・送信、Google Drive閲覧・作成、Google Photos管理、汎用Webブラウジングに対応。ログインセッションを維持したまま、APIキー不要でGoogle各サービスをブラウザUI経由で直接操作できます。"
  },
  "features": {
    "bot_user": {
      "display_name": "mugibow",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/mugiclaw",
        "description": "むぎぼーを操作するコマンド",
        "usage_hint": "[profile|schedule|run|memories|model|reaction|canvas|msg|bookmark|list|deploy|help]"
      }
    ],
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "channels:history",
        "groups:history",
        "channels:read",
        "groups:read",
        "users:read",
        "files:write",
        "files:read",
        "im:write",
        "im:history",
        "commands",
        "reactions:read",
        "canvases:write",
        "canvases:read",
        "bookmarks:write",
        "bookmarks:read"
      ],
      "user": [
        "search:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "app_home_opened",
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
