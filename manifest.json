{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "mugi-claw",
    "description": "AIアシスタント犬むぎぼー。Claude Code CLIでタスクを実行するわん！",
    "background_color": "#F5A623",
    "long_description": "Slackに常駐するAIアシスタント。@メンションでClaude Code CLIにタスクを委譲し、進捗をリアルタイムにスレッドに投稿します。ブラウザ操作によるGoogle連携（Gmail、Drive、Photos）にも対応。"
  },
  "features": {
    "bot_user": {
      "display_name": "むぎぼー",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "channels:history",
        "groups:history",
        "channels:read",
        "groups:read",
        "search:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
