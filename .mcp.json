{
  "mcpServers": {
    "browser": {
      "command": "node",
      "args": ["dist/browser/mcp-server.js"],
      "env": {
        "CHROME_DEBUGGING_PORT": "9222"
      }
    },
    "desktop": {
      "command": "node",
      "args": ["dist/desktop/mcp-server.js"]
    },
    "mobile": {
      "command": "npx",
      "args": ["-y", "@mobilenext/mobile-mcp@latest"]
    }
  }
}
